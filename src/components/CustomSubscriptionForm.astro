---
import presetsData from '../data/presets.json';
import { CATEGORIES } from '../scripts/subscriptions';
import type { SubscriptionCategory } from '../scripts/subscriptions';
---

<section id="add" class="add-section" aria-label="サブスクリプション追加">
  <h2 class="section-title">サブスクを追加</h2>

  <!-- タブ切替 -->
  <div class="tab-bar" role="tablist" aria-label="追加方法">
    <button role="tab" class="tab active" id="tab-preset" aria-selected="true" aria-controls="panel-preset" type="button">
      プリセットから選ぶ
    </button>
    <button role="tab" class="tab" id="tab-custom" aria-selected="false" aria-controls="panel-custom" type="button">
      カスタム追加
    </button>
  </div>

  <!-- プリセットパネル -->
  <div id="panel-preset" role="tabpanel" aria-labelledby="tab-preset" class="tab-panel">
    <!-- カテゴリフィルター -->
    <div class="chips-wrap" role="group" aria-label="カテゴリフィルター">
      <button class="chip active" data-cat="all" type="button">すべて</button>
      {Object.entries(CATEGORIES).map(([key, val]) => (
        <button class="chip" data-cat={key} type="button">{val.label}</button>
      ))}
    </div>

    <!-- プリセットグリッド -->
    <div class="preset-grid" id="preset-grid" role="list" aria-label="プリセットサービス一覧">
      {presetsData.map((preset) => (
        <button
          class="preset-card"
          data-preset={JSON.stringify(preset)}
          data-category={preset.category}
          type="button"
          role="listitem"
          aria-label={`${preset.name}を追加`}
        >
          <div class="preset-icon" style={`background: ${preset.color}`} aria-hidden="true">
            <img src={preset.icon} width="22" height="22" alt="" loading="lazy" />
          </div>
          <div class="preset-info">
            <p class="preset-name">{preset.name}</p>
            <p class="preset-price">¥{preset.price.toLocaleString('ja-JP')}<span class="preset-cycle">/{preset.billingCycle === 'monthly' ? '月' : '年'}</span></p>
          </div>
          <span class="preset-added-badge" aria-label="登録済み" hidden>✓</span>
        </button>
      ))}
    </div>
  </div>

  <!-- カスタムパネル -->
  <div id="panel-custom" role="tabpanel" aria-labelledby="tab-custom" class="tab-panel" hidden>
    <form id="custom-form" class="custom-form" novalidate>
      <div class="form-grid">
        <div class="form-group col-span-2">
          <label for="c-name" class="form-label">サービス名 <span class="required" aria-hidden="true">*</span></label>
          <input type="text" id="c-name" placeholder="例: Netflix" required maxlength="50" />
          <span class="form-error" id="c-name-error" role="alert"></span>
        </div>

        <div class="form-group">
          <label for="c-price" class="form-label">金額（円） <span class="required" aria-hidden="true">*</span></label>
          <input type="number" id="c-price" placeholder="1980" required min="0" step="1" />
          <span class="form-error" id="c-price-error" role="alert"></span>
        </div>

        <div class="form-group">
          <label class="form-label">支払い周期</label>
          <div class="cycle-toggle">
            <label class="cycle-option">
              <input type="radio" name="c-cycle" value="monthly" checked /> 月額
            </label>
            <label class="cycle-option">
              <input type="radio" name="c-cycle" value="yearly" /> 年額
            </label>
          </div>
        </div>

        <div class="form-group">
          <label for="c-category" class="form-label">カテゴリ</label>
          <select id="c-category">
            {Object.entries(CATEGORIES).map(([key, val]) => (
              <option value={key}>{val.label}</option>
            ))}
          </select>
        </div>

        <div class="form-group">
          <label for="c-start" class="form-label">開始日</label>
          <input type="date" id="c-start" />
        </div>

        <div class="form-group col-span-2">
          <label for="c-memo" class="form-label">メモ（任意）</label>
          <textarea id="c-memo" rows="2" placeholder="備考など..." maxlength="200"></textarea>
        </div>
      </div>

      <div class="form-footer">
        <button type="submit" class="btn-primary">追加する</button>
      </div>
    </form>
  </div>
</section>

<!-- プリセット追加モーダル -->
<dialog id="preset-modal" aria-modal="true" aria-labelledby="preset-modal-title">
  <h2 id="preset-modal-title" class="modal-title"></h2>
  <div class="modal-preset-info">
    <span class="modal-price price-display" id="modal-price"></span>
    <span class="modal-cycle" id="modal-cycle"></span>
  </div>
  <form id="preset-form" class="modal-form" novalidate>
    <input type="hidden" id="p-preset-data" />
    <div class="form-group">
      <label for="p-price" class="form-label">金額（編集可）</label>
      <input type="number" id="p-price" min="0" step="1" />
    </div>
    <div class="form-group">
      <label class="form-label">支払い周期</label>
      <div class="cycle-toggle" id="p-cycle-wrap">
        <label class="cycle-option">
          <input type="radio" name="p-cycle" value="monthly" checked /> 月額
        </label>
        <label class="cycle-option" id="p-yearly-option" hidden>
          <input type="radio" name="p-cycle" value="yearly" /> 年額
        </label>
      </div>
    </div>
    <div class="form-group">
      <label for="p-start" class="form-label">開始日</label>
      <input type="date" id="p-start" />
    </div>
    <div class="modal-actions">
      <button type="button" class="btn-secondary" id="preset-cancel">キャンセル</button>
      <button type="submit" class="btn-primary">追加する</button>
    </div>
  </form>
</dialog>

<script>
  import { SubscriptionStore } from '../scripts/store';
  import type { SubscriptionCategory, BillingCycle } from '../scripts/subscriptions';
  import { showToast } from '../scripts/toast';

  // ---- タブ切替 ----
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab[role="tab"]');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      const panelId = tab.getAttribute('aria-controls')!;
      document.querySelectorAll<HTMLElement>('.tab-panel').forEach(p => {
        p.hidden = p.id !== panelId;
      });
    });
  });

  // ---- カテゴリフィルター ----
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip[data-cat]');
  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      chips.forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      const cat = chip.dataset.cat;
      document.querySelectorAll<HTMLButtonElement>('.preset-card').forEach(card => {
        const match = cat === 'all' || card.dataset.category === cat;
        (card.closest('li') as HTMLElement | null)?.style.setProperty('display', match ? '' : 'none');
        card.style.display = match ? '' : 'none';
      });
    });
  });

  // ---- 登録済みバッジ更新 ----
  function updateBadges() {
    const subs = SubscriptionStore.getAll();
    document.querySelectorAll<HTMLButtonElement>('.preset-card').forEach(card => {
      const preset = JSON.parse(card.dataset.preset ?? '{}') as { name: string };
      const badge = card.querySelector<HTMLElement>('.preset-added-badge');
      if (badge) badge.hidden = !subs.some(s => s.name === preset.name && s.isActive);
    });
  }

  updateBadges();
  window.addEventListener('subtracker:updated', updateBadges);

  // ---- プリセットモーダル ----
  document.querySelectorAll<HTMLButtonElement>('.preset-card').forEach(card => {
    card.addEventListener('click', () => {
      const preset = JSON.parse(card.dataset.preset ?? '{}') as {
        name: string; price: number; billingCycle: BillingCycle; category: string; color: string; icon: string; yearlyPrice?: number;
      };

      document.getElementById('preset-modal-title')!.textContent = preset.name;
      (document.getElementById('p-preset-data') as HTMLInputElement).value = card.dataset.preset ?? '';
      (document.getElementById('p-price') as HTMLInputElement).value = String(preset.price);
      (document.getElementById('p-start') as HTMLInputElement).value = new Date().toISOString().slice(0, 10);

      // 年額オプション
      const yearlyOpt = document.getElementById('p-yearly-option')!;
      yearlyOpt.hidden = !preset.yearlyPrice;

      const radios = document.querySelectorAll<HTMLInputElement>('input[name="p-cycle"]');
      radios.forEach(r => { r.checked = r.value === preset.billingCycle; });

      document.getElementById('modal-price')!.textContent = `¥${preset.price.toLocaleString('ja-JP')}`;
      document.getElementById('modal-cycle')!.textContent = preset.billingCycle === 'monthly' ? '/月' : '/年';

      (document.getElementById('preset-modal') as HTMLDialogElement).showModal();
    });
  });

  document.getElementById('preset-cancel')?.addEventListener('click', () => {
    (document.getElementById('preset-modal') as HTMLDialogElement).close();
  });

  document.getElementById('preset-modal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) (e.currentTarget as HTMLDialogElement).close();
  });

  document.getElementById('preset-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const presetRaw = (document.getElementById('p-preset-data') as HTMLInputElement).value;
    const preset = JSON.parse(presetRaw) as { name: string; category: SubscriptionCategory; color: string; icon: string };
    const price = Number((document.getElementById('p-price') as HTMLInputElement).value);
    const startDate = (document.getElementById('p-start') as HTMLInputElement).value;
    const billingCycle = (document.querySelector<HTMLInputElement>('input[name="p-cycle"]:checked'))?.value as BillingCycle ?? 'monthly';

    SubscriptionStore.add({
      name: preset.name,
      price,
      billingCycle,
      category: preset.category,
      startDate: startDate || new Date().toISOString().slice(0, 10),
      icon: preset.icon,
      color: preset.color,
      isPreset: true,
      isActive: true,
    });

    (document.getElementById('preset-modal') as HTMLDialogElement).close();
    showToast(`「${preset.name}」を追加しました`);
  });

  // ---- カスタムフォーム ----
  const today = new Date().toISOString().slice(0, 10);
  (document.getElementById('c-start') as HTMLInputElement).value = today;

  document.getElementById('custom-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = (document.getElementById('c-name') as HTMLInputElement).value.trim();
    const price = Number((document.getElementById('c-price') as HTMLInputElement).value);
    const category = (document.getElementById('c-category') as HTMLSelectElement).value as SubscriptionCategory;
    const startDate = (document.getElementById('c-start') as HTMLInputElement).value || today;
    const memo = (document.getElementById('c-memo') as HTMLTextAreaElement).value.trim();
    const billingCycle = (document.querySelector<HTMLInputElement>('input[name="c-cycle"]:checked'))?.value as BillingCycle ?? 'monthly';

    const nameErr = document.getElementById('c-name-error')!;
    const priceErr = document.getElementById('c-price-error')!;
    nameErr.textContent = '';
    priceErr.textContent = '';

    if (!name) { nameErr.textContent = 'サービス名を入力してください'; return; }
    if (isNaN(price) || price < 0) { priceErr.textContent = '正しい金額を入力してください'; return; }

    SubscriptionStore.add({
      name,
      price,
      billingCycle,
      category,
      startDate,
      icon: `/brand/category-${category}.svg`,
      color: '#71717A',
      isPreset: false,
      isActive: true,
      memo: memo || undefined,
    });

    (document.getElementById('custom-form') as HTMLFormElement).reset();
    (document.getElementById('c-start') as HTMLInputElement).value = today;
    showToast(`「${name}」を追加しました`);
  });
</script>

<style>
  .add-section {
    margin: 3rem 0;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  /* タブ */
  .tab-bar {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-subtle);
    padding-bottom: 0;
  }

  .tab {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-secondary);
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    margin-bottom: -1px;
    font-family: inherit;
  }

  .tab:hover {
    color: var(--text-primary);
  }

  .tab.active {
    color: var(--accent-blue);
    border-bottom-color: var(--accent-blue);
  }

  /* カテゴリチップ */
  .chips-wrap {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    margin-bottom: 1.25rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .chips-wrap::-webkit-scrollbar { display: none; }

  /* プリセットグリッド */
  .preset-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .preset-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .preset-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    cursor: pointer;
    transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
    text-align: left;
    font-family: inherit;
    animation: scaleIn 0.25s ease-out both;
  }

  .preset-card:hover {
    background: var(--bg-tertiary);
    transform: translateY(-1px);
    box-shadow: var(--shadow-card);
  }

  .preset-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .preset-info {
    min-width: 0;
  }

  .preset-name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 0.125rem;
  }

  .preset-price {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .preset-cycle {
    font-size: 0.6875rem;
    color: var(--text-tertiary);
  }

  .preset-added-badge {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: var(--accent-green);
    color: #fff;
    font-size: 0.625rem;
    font-weight: 700;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* カスタムフォーム */
  .custom-form {
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    padding: 1.5rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
    .col-span-2 {
      grid-column: span 1;
    }
  }

  .col-span-2 {
    grid-column: span 2;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .required {
    color: var(--accent-red);
  }

  .form-error {
    font-size: 0.75rem;
    color: var(--accent-red);
    min-height: 1rem;
  }

  .cycle-toggle {
    display: flex;
    gap: 1.25rem;
    padding: 0.625rem 0;
  }

  .cycle-option {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    cursor: pointer;
    font-size: 0.9375rem;
    color: var(--text-primary);
  }

  .form-footer {
    margin-top: 1.25rem;
    display: flex;
    justify-content: flex-end;
  }

  /* モーダル */
  .modal-title {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .modal-preset-info {
    margin-bottom: 1.25rem;
    color: var(--text-secondary);
    font-size: 1.25rem;
    font-weight: 600;
  }

  .modal-price {
    color: var(--text-primary);
  }

  .modal-cycle {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-left: 0.25rem;
  }

  .modal-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .modal-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: flex-end;
    margin-top: 0.5rem;
  }
</style>
