---
---

<!-- カードはJSで動的生成 -->
<template id="subscription-card-template">
  <article class="sub-card card" data-id="">
    <div class="card-left">
      <div class="card-icon" aria-hidden="true"></div>
      <div class="card-info">
        <h3 class="card-name"></h3>
        <span class="card-category"></span>
      </div>
    </div>
    <div class="card-right">
      <div class="card-price-wrap">
        <span class="card-price price-display"></span>
        <span class="card-cycle"></span>
      </div>
      <div class="card-actions">
        <button class="action-btn toggle-btn" aria-label="有効/無効切替" title="有効/無効を切替" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18.36 6.64a9 9 0 1 1-12.73 0"/>
            <line x1="12" y1="2" x2="12" y2="12"/>
          </svg>
        </button>
        <button class="action-btn edit-btn" aria-label="編集" title="編集" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
        </button>
        <button class="action-btn delete-btn" aria-label="削除" title="削除" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6l-1 14H6L5 6"/>
            <path d="M10 11v6M14 11v6"/>
            <path d="M9 6V4h6v2"/>
          </svg>
        </button>
      </div>
    </div>
  </article>
</template>

<style is:global>
  .sub-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    gap: 1rem;
    animation: scaleIn 0.3s ease-out both;
    overflow: hidden;
  }

  .sub-card.inactive {
    opacity: 0.45;
  }

  .card-left {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    min-width: 0;
  }

  .card-icon {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.125rem;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .card-info {
    min-width: 0;
  }

  .card-name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 0.25rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-category {
    font-size: 0.75rem;
    color: var(--text-secondary);
    background: var(--bg-tertiary);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .card-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .card-price-wrap {
    text-align: right;
  }

  .card-price {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--text-primary);
    display: block;
  }

  .card-cycle {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .card-actions {
    display: flex;
    gap: 0.25rem;
  }

  .action-btn {
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    border: none;
    background: none;
    color: var(--text-secondary);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  .action-btn:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
  }

  .delete-btn:hover {
    background: rgba(255, 69, 58, 0.12);
    color: var(--accent-red);
  }
</style>
